{
  "name": "cf-tuiguang-tongji",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "基于 Cloudflare Worker 的企业推广监控平台",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init:local": "wrangler d1 execute cf-tuiguang-tongji --file=./src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute cf-tuiguang-tongji --remote --file=./src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute cf-tuiguang-tongji --file=./src/db/seed.sql",
    "r2:create": "echo 'wrangler r2 bucket create cf-tuiguang-qr'",
    "kv:create": "echo 'wrangler kv namespace create KV'",
    "secret:agent": "echo 'wrangler secret put AGENT_API_KEY'",
    "secret:session": "echo 'wrangler secret put SESSION_SECRET'"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  },
  "dependencies": {
    "nanoid": "^5.0.7",
    "qrcode": "^1.5.4",
    "qrcode-svg": "^1.1.0",
    "ua-parser-js": "^1.0.39",
    "zod": "^3.23.8"
  }
}
